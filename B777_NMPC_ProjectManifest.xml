  <PlantModel>
    <Name>B777_6DOF_Plant</Name>
    <RecommendedSimulinkBlock>6DOF Quaternion</RecommendedSimulinkBlock>
    <Description>The full nonlinear 6-DOF plant should include aerodynamic forces and moments, engine thrust, gravity, flap configuration, landing gear, mass, inertia, actuators and sensors.</Description>
    <LoggedStates>
      <State>h</State>
      <State>Vtas</State>
      <State>Mach</State>
      <State>alpha</State>
      <State>beta</State>
      <State>phi</State>
      <State>theta</State>
      <State>psi</State>
      <State>p</State>
      <State>q</State>
      <State>r</State>
      <State>position_NED</State>
      <State>quaternion</State>
      <State>Nz</State>
      <State>throttle</State>
      <State>elevator</State>
      <State>aileron</State>
      <State>rudder</State>
    </LoggedStates>
    <Aerodynamics>
      <InitialModel>Simple coefficient model: CL, CD, Cm, CY, Cl and Cn as functions of alpha, beta, p, q, r, control-surface deflections, Mach number and configuration.</InitialModel>
      <TargetModel>Use aerodynamic tables dependent on Mach, alpha, beta, flap configuration, landing gear, spoilers and control-surface deflections.</TargetModel>
    </Aerodynamics>
    <Engine>
      <InitialModel>Idle-to-maximum throttle mapping, altitude/Mach thrust lapse and first-order spool dynamics are implemented in b777_engine_model.m and b777_engine_forces_moments.m.</InitialModel>
      <TargetModel>Thrust and fuel-flow tables as functions of altitude, Mach number and throttle command.</TargetModel>
    </Engine>
  </PlantModel>
  <NMPCDesign>
    <GeneralStrategy>Do not start with one large NMPC for the complete 6-DOF model. Build a separate Longitudinal NMPC first, then a Lateral NMPC, and only later an Integrated Trajectory NMPC.</GeneralStrategy>
    <Controller name="Longitudinal_NMPC">
      <Purpose>Control altitude, airspeed, flight-path angle, pitch attitude and thrust.</Purpose>
      <States>
        <State>V</State>
        <State>alpha</State>
        <State>q</State>
        <State>theta</State>
        <State>h</State>
        <State>T</State>
      </States>
      <Inputs>
        <Input>elevator_command</Input>
        <Input>throttle_command</Input>
      </Inputs>
      <Outputs>
        <Output>V</Output>
        <Output>alpha</Output>
        <Output>theta</Output>
        <Output>h</Output>
        <Output>gamma</Output>
      </Outputs>
      <SupportedModes>
        <Mode>PITCH_HOLD</Mode>
        <Mode>ALT_HOLD</Mode>
        <Mode>VS</Mode>
        <Mode>FLCH</Mode>
        <Mode>VNAV_PATH_SIMPLIFIED</Mode>
        <Mode>SPEED_HOLD</Mode>
        <Mode>GLIDESLOPE_CAPTURE</Mode>
      </SupportedModes>
      <Constraints>
        <Constraint>alpha_min = -4 deg</Constraint>
        <Constraint>alpha_max = 12 deg</Constraint>
        <Constraint>theta_min = -10 deg</Constraint>
        <Constraint>theta_max = 20 deg</Constraint>
        <Constraint>gamma_min = -6 deg</Constraint>
        <Constraint>gamma_max = 8 deg</Constraint>
        <Constraint>Nz_min = 0.5 g</Constraint>
        <Constraint>Nz_max = 1.4 g</Constraint>
        <Constraint>elevator_min = -25 deg</Constraint>
        <Constraint>elevator_max = 25 deg</Constraint>
        <Constraint>elevator_rate_limit = +/- 10 deg/s</Constraint>
        <Constraint>throttle_min = 0</Constraint>
        <Constraint>throttle_max = 1</Constraint>
        <Constraint>throttle_rate_limit = +/- 0.15 / s</Constraint>
      </Constraints>
      <SampleTime>0.2 s</SampleTime>
      <PredictionHorizon>40</PredictionHorizon>
      <ControlHorizon>10</ControlHorizon>
    </Controller>
    <Controller name="Lateral_NMPC">
      <Purpose>Control heading, track, bank angle, cross-track error, sideslip and localizer capture.</Purpose>
      <States>
        <State>beta</State>
        <State>p</State>
        <State>r</State>
        <State>phi</State>
        <State>psi</State>
        <State>cross_track_error</State>
      </States>
      <Inputs>
        <Input>aileron_command</Input>
        <Input>rudder_command</Input>
      </Inputs>
      <SupportedModes>
        <Mode>ROLL_HOLD</Mode>
        <Mode>HDG_SEL</Mode>
        <Mode>TRK_HOLD</Mode>
        <Mode>LNAV_SIMPLIFIED</Mode>
        <Mode>LOCALIZER_CAPTURE</Mode>
      </SupportedModes>
      <Constraints>
        <Constraint>bank_angle_limit = +/- 30 deg normal operation</Constraint>
        <Constraint>aileron_limit = +/- 25 deg</Constraint>
        <Constraint>rudder_limit = +/- 30 deg</Constraint>
        <Constraint>aileron_rate_limit = project-defined</Constraint>
        <Constraint>rudder_rate_limit = project-defined</Constraint>
        <Constraint>sideslip should be minimized</Constraint>
      </Constraints>
      <SampleTime>0.2 s</SampleTime>
      <PredictionHorizon>35</PredictionHorizon>
      <ControlHorizon>8</ControlHorizon>
    </Controller>
    <Controller name="Integrated_Trajectory_NMPC">
      <Purpose>Final integrated controller for LNAV, VNAV, ILS, energy management and constraint handling.</Purpose>
      <States>
        <State>V</State>
        <State>alpha</State>
        <State>beta</State>
        <State>p</State>
        <State>q</State>
        <State>r</State>
        <State>phi</State>
        <State>theta</State>
        <State>psi</State>
        <State>h</State>
        <State>path_distance_s</State>
        <State>cross_track_error</State>
        <State>T</State>
      </States>
      <Inputs>
        <Input>elevator_command</Input>
        <Input>aileron_command</Input>
        <Input>rudder_command</Input>
        <Input>throttle_command</Input>
      </Inputs>
      <SampleTime>0.5 s</SampleTime>
      <PredictionHorizon>40</PredictionHorizon>
      <ControlHorizon>10</ControlHorizon>
    </Controller>
  </NMPCDesign>
  <Milestones>
    <Milestone id="M1" name="Nonlinear 6-DOF Plant">
      <Description>Build a B777-like 6-DOF aircraft model without the autopilot.</Description>
      <Tasks>
        <Task>Collect geometry and mass data from Boeing ACAP.</Task>
        <Task>Implement the ISA atmosphere.</Task>
        <Task>Implement the initial aerodynamic model.</Task>
        <Task>Implement the initial engine model.</Task>
        <Task>Connect forces and moments to the 6DOF Quaternion block.</Task>
        <Task>Log the basic flight states.</Task>
      </Tasks>
    </Milestone>
    <Milestone id="M2" name="Trim and Basic Stability">
      <Description>The aircraft should be trimmable and dynamically plausible.</Description>
      <Tasks>
        <Task>Write trim_cruise.m.</Task>
        <Task>Write trim_climb.m.</Task>
        <Task>Write trim_descent.m.</Task>
        <Task>Write trim_approach.m.</Task>
        <Task>Test the phugoid, short-period, Dutch-roll and roll modes.</Task>
        <Task>Compare performance with public references such as OpenAP.</Task>
      </Tasks>
    </Milestone>
    <Milestone id="M3" name="Longitudinal NMPC">
      <Description>NMPC maintains altitude, airspeed and vertical path.</Description>
      <Tasks>
        <Task>Implement the model x = [V, alpha, q, theta, h, T].</Task>
        <Task>Implement the state function, output function, cost and constraints.</Task>
        <Task>Test ALT HOLD, SPEED HOLD, VS, FLCH and simplified VNAV PATH.</Task>
        <Task>Run the controller in Simulink through the Nonlinear MPC Controller block.</Task>
      </Tasks>
    </Milestone>
    <Milestone id="M4" name="Lateral NMPC">
      <Description>NMPC controls heading, bank angle and lateral-path error.</Description>
      <Tasks>
        <Task>Implement the model x = [beta, p, r, phi, psi, crossTrackError].</Task>
        <Task>Implement constraints for bank angle, aileron, rudder and sideslip.</Task>
        <Task>Test HDG SEL and capture of a simple LNAV path.</Task>
        <Task>Add simplified localizer capture.</Task>
      </Tasks>
    </Milestone>
    <Milestone id="M5" name="Mode Manager and MCP">
      <Description>The autopilot has modes, arming logic and capture logic.</Description>
      <Tasks>
        <Task>Add MCP controls: selected speed, heading, altitude and vertical speed.</Task>
        <Task>Add the mode manager: armed and active modes.</Task>
        <Task>Add a reference generator for h_ref, V_ref, gamma_ref, psi_ref and crossTrack_ref.</Task>
        <Task>Consider Stateflow for mode logic.</Task>
      </Tasks>
    </Milestone>
    <Milestone id="M6" name="Integrated NMPC and Full Mission">
      <Description>Full mission demonstrator with LNAV/VNAV/ILS.</Description>
      <Tasks>
        <Task>Integrate Longitudinal and Lateral NMPC or create Integrated NMPC.</Task>
        <Task>Add waypoint-based LNAV.</Task>
        <Task>Add VNAV descent with altitude and speed constraints.</Task>
        <Task>Add LOC and GS capture.</Task>
        <Task>Demonstrate manual takeoff, AP engage, climb, cruise, descent and ILS approach.</Task>
      </Tasks>
    </Milestone>
  </Milestones>
